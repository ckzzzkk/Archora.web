# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VIGA_WORKER_URL=http://localhost:8000

# Optional (for VIGA agent LLM calls)
OPENAI_API_KEY=sk-...
MESHY_API_KEY=your-meshy-key

# Paths (customize for your conda installation)
CONDA_BASE_PATH=/path/to/conda
BLENDER_PATH=/usr/local/blender
