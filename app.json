{
  "expo": {
    "name": "ASORIA - AI Architecture Design",
    "slug": "asoria",
    "description": "Design your dream space with AI. Generate floor plans, visualize in 3D, and walk through your creations.",
    "version": "1.0.0",
    "backgroundColor": "#1A1A1A",
    "scheme": "asoria",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "primaryColor": "#C8C8C8",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.asoria.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "ASORIA",
        "CFBundleName": "ASORIA",
        "NSCameraUsageDescription": "ASORIA uses your camera for AR room scanning",
        "NSMicrophoneUsageDescription": "ASORIA uses your microphone for voice prompts",
        "NSPhotoLibraryUsageDescription": "ASORIA saves your designs and exports renders to your photo library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.asoria.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "ASORIA",
      "shortName": "ASORIA",
      "description": "AI-powered architecture design platform",
      "lang": "en",
      "themeColor": "#1A1A1A",
      "backgroundColor": "#1A1A1A"
    },
    "plugins": [
      ["expo-build-properties", {
        "android": {
          "enableHermes": true,
          "enableProguardInReleaseBuilds": true,
          "enableShrinkResourcesInReleaseBuilds": true
        },
        "ios": {
          "flipper": false
        }
      }],
      "./plugin/withARKitModule",
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "ASORIA uses your microphone for voice-to-prompt architectural description."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "ASORIA needs camera access for AR features",
          "enableMicrophonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A1A1A",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "ASORIA",
          "androidNotificationChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1697aad8-bba0-442d-ac24-275a5ddd8e74"
      }
    },
    "owner": "ckng",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1697aad8-bba0-442d-ac24-275a5ddd8e74"
    }
  }
}
