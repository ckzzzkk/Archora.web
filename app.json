{
  "expo": {
    "ios": {
      "bundleIdentifier": "com.asoria.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "ASORIA needs camera access for AR features"
      }
    },
    "android": {
      "package": "com.asoria.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "name": "ASORIA - AI Architecture Design",
    "slug": "asoria-app-v2",
    "description": "Design your dream space with AI. Generate floor plans, visualize in 3D, and walk through your creations.",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "ASORIA",
      "shortName": "ASORIA",
      "description": "AI-powered architecture design platform",
      "lang": "en",
      "themeColor": "#1A1A1A",
      "backgroundColor": "#1A1A1A"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableHermes": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "flipper": false
          }
        }
      ],
      "./plugin/withARKitModule",
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "ASORIA uses your microphone for voice-to-prompt architectural description."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "ASORIA needs camera access for AR features",
          "enableMicrophonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A1A1A",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "ASORIA",
          "androidNotificationChannel": "default"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "aff88d2f-a5de-4a5a-9fcb-b8a29c56e6f3"
      }
    },
    "owner": "crokora",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/aff88d2f-a5de-4a5a-9fcb-b8a29c56e6f3"
    }
  }
}
