# node_modules — EAS installs these fresh during build
node_modules/

# Git worktrees and local tooling directories (not needed for build)
.worktrees/
.gitnexus/
.claude/

# Old build artifacts in project root
*.apk
*.aab
*.jks

# Native build outputs — regenerated fresh on the EAS builder. MUST be excluded:
# local Gradle/CMake caches embed absolute /home paths that break the cloud native
# build, and they balloon the upload archive (android/app/build alone is ~3 GB).
android/app/build/
android/build/
android/.gradle/
android/.kotlin/
android/.cxx/
android/app/.cxx/
ios/build/
ios/Pods/
ios/DerivedData/

# Test files and docs
src/__tests__/
docs/
tasks/
competitor-profiles/

# Dev tooling
vitest.config.ts
tsconfig.json

# Local secrets (never upload)
.env
.env.local
.env.*.local

# Large media that's loaded from CDN at runtime
assets/videos/

# OS / editor noise
.DS_Store
Thumbs.db
*.log
