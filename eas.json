{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "${SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_STRIPE_PRICE_CREATOR_MONTHLY": "${STRIPE_PRICE_CREATOR_MONTHLY}",
        "EXPO_PUBLIC_STRIPE_PRICE_CREATOR_ANNUAL": "${STRIPE_PRICE_CREATOR_ANNUAL}",
        "EXPO_PUBLIC_STRIPE_PRICE_PRO_MONTHLY": "${STRIPE_PRICE_PRO_MONTHLY}",
        "EXPO_PUBLIC_STRIPE_PRICE_PRO_ANNUAL": "${STRIPE_PRICE_PRO_ANNUAL}",
        "EXPO_PUBLIC_STRIPE_PRICE_ARCHITECT_MONTHLY": "${STRIPE_PRICE_ARCHITECT_MONTHLY}",
        "EXPO_PUBLIC_STRIPE_PRICE_ARCHITECT_ANNUAL": "${STRIPE_PRICE_ARCHITECT_ANNUAL}",
        "EXPO_PUBLIC_REVENUECAT_IOS_KEY": "${REVENUECAT_IOS_KEY}",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "${REVENUECAT_ANDROID_KEY}"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "resourceClass": "medium"
      },
      "ios": {
        "simulator": true,
        "buildConfiguration": "Debug",
        "resourceClass": "medium"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "ios": {
        "buildConfiguration": "Release",
        "resourceClass": "medium"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium"
      },
      "ios": {
        "buildConfiguration": "Release",
        "resourceClass": "medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      }
    }
  }
}
