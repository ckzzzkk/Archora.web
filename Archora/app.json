{
  "expo": {
    "name": "Asoria",
    "slug": "asoria",
    "version": "1.0.0",
    "backgroundColor": "#1A1A1A",
    "scheme": "asoria",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.asoria.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "ASORIA uses your camera for AR room scanning",
        "NSMicrophoneUsageDescription": "ASORIA uses your microphone for voice prompts",
        "NSPhotoLibraryUsageDescription": "ASORIA saves your designs and exports renders to your photo library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.asoria.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "Asoria uses your microphone for voice-to-prompt architectural description."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "ASORIA needs camera access for AR features",
          "enableMicrophonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1697aad8-bba0-442d-ac24-275a5ddd8e74"
      }
    },
    "owner": "ckng"
  }
}
