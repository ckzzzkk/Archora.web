{
  "expo": {
    "name": "Asoria",
    "slug": "crokora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.archora.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Asoria uses your camera to scan rooms and detect furniture for AR reconstruction.",
        "NSMicrophoneUsageDescription": "Asoria uses your microphone for voice-to-prompt architectural description."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.archora.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "Asoria uses your microphone for voice-to-prompt architectural description."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "FILL_IN_AFTER_EAS_INIT"
      }
    }
  }
}